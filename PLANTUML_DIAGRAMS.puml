@startuml System_Architecture
title GreenChem Navigator - System Architecture

skinparam componentStyle rectangle
skinparam shadowing false
skinparam packageStyle rectangle

actor "User / Chemist" as User

package "Python FastAPI Backend" {
  component "Frontend Static Files\nHTML + CSS + JS" as Frontend
  component "API Routes\n/main.py" as API
  component "Formula Parser\n/parser.py" as Parser
  component "Recommender Engine\n/recommender.py" as Recommender
  component "Compatibility Rules\n/compatibility.py" as Rules
  component "ML Compatibility Model\n/ml/model.py" as MLModel
  component "PDF Report Generator\n/pdf_report.py" as PDF
  component "Optional LLM Layer\n/llm.py" as LLM
}

database "Structured Knowledge Base\nknowledge_base.json" as KB
database "Training Dataset\ntraining_data.csv" as Dataset
database "Trained Model\ngreenchem_model.joblib" as ModelFile
cloud "PubChem Public Metadata\noptional import" as PubChem
cloud "Chemistry News Sources\nC&EN / ACS" as News

User --> Frontend : Fill form / click analyze
Frontend --> API : HTTP requests
API --> Parser : Parse current process
API --> Recommender : Analyze formula
Recommender --> KB : Solvents, catalysts,\nhazards, replacements
Recommender --> Rules : Compatibility checks
Recommender --> MLModel : Predict compatibility
MLModel --> ModelFile : Load model artifact
API --> PDF : Generate report
API --> News : Fetch recent news
LLM ..> Recommender : Optional explanation fallback
PubChem ..> KB : Enrich solvent metadata
Dataset --> ModelFile : Train RandomForest

note right of LLM
The LLM is used as an explanation
or fallback layer, not as the final
chemical decision maker.
end note

note bottom of Recommender
Final decision belongs to the user
or a qualified human expert.
Wet lab validation is required.
end note

@enduml


@startuml User_Workflow
title GreenChem Navigator - User Workflow

skinparam shadowing false

start
:User opens web app;
:User fills structured input fields;
note right
Examples:
- solvent
- catalyst
- catalyst role
- amounts
- temperature
- pH
end note

:Frontend builds backend formula text;
:User clicks Analyze;
:Backend parses current process;
:System checks knowledge base;
:System checks compatibility rules;
:System asks ML model for compatibility signal;

if (Compatible alternatives found?) then (yes)
  :Show recommended alternatives;
  :Show current vs suggested formula;
  :Show visual simulation;
  :Allow PDF export;
else (no)
  :Show insufficient data or no compatible alternative;
  :Ask user to review input;
endif

:User reviews evidence and warnings;
:Human expert makes final decision;
stop

@enduml


@startuml Analyze_Sequence
title GreenChem Navigator - Analyze Request Sequence

skinparam shadowing false

actor User
participant "Web Frontend" as FE
participant "FastAPI\n/main.py" as API
participant "Parser\n/parser.py" as Parser
participant "Recommender\n/recommender.py" as Rec
database "Knowledge Base\nknowledge_base.json" as KB
participant "Compatibility Rules\n/compatibility.py" as Rules
participant "ML Model\n/ml/model.py" as ML

User -> FE : Fill process fields
FE -> FE : Build formula_text
User -> FE : Click Analyze
FE -> API : POST /analyze
API -> Rec : analyze(formula_text)
Rec -> Parser : parse_formula_text()
Parser --> Rec : compounds + environment
Rec -> KB : find current solvent
Rec -> KB : find catalyst
Rec -> KB : get replacement records

loop For each candidate solvent
  Rec -> Rules : acid/base compatibility check
  Rules --> Rec : compatible? + notes
  Rec -> ML : predict compatibility
  ML --> Rec : model signal
end

Rec --> API : AnalyzeResponse
API --> FE : JSON result
FE -> User : Display recommendations,\nevidence, simulation

@enduml


@startuml ML_Training_Pipeline
title GreenChem Navigator - ML Training Pipeline

skinparam shadowing false

start
:Load local knowledge base;
:Read solvents;
:Read catalysts and catalyst roles;
:Define temperature list;
note right
Temperatures:
0C, 25C, 40C,
60C, 90C, 120C
end note

:Generate combinations;
note right
65 solvents x 20 catalyst roles
x 6 temperatures = 7,800 rows
end note

:Apply compatibility rules;
:Create label is_compatible;
:Build ML feature columns;
:Write training_data.csv;
:Split train/test data;
:Train RandomForestClassifier;
:Evaluate accuracy and report;
:Save greenchem_model.joblib;
stop

@enduml


@startuml Dataset_Source_Flow
title GreenChem Navigator - Dataset Source And Feature Flow

skinparam shadowing false

database "knowledge_base.json" as KB {
}

cloud "Optional PubChem Metadata" as PubChem
component "Solvent + Catalyst\nCurated Records" as Curated
component "Compatibility Rules" as Rules
component "Feature Builder\nfeatures.py" as Features
database "training_data.csv\n7,800 rows / 28 columns" as CSV
component "RandomForestClassifier" as RF
database "greenchem_model.joblib" as Joblib

PubChem --> KB : CID, formula,\nmolecular weight,\nSMILES, hazard text
Curated --> KB : solvent colors,\nboiling points,\nincompatibilities
KB --> Rules : chemical facts
Rules --> CSV : is_compatible labels
KB --> Features : solvent/catalyst facts
Features --> CSV : numeric feature columns
CSV --> RF : training data
RF --> Joblib : saved model

note bottom of CSV
The dataset is generated by the project.
It is not a laboratory experimental dataset.
It is useful for prototype decision support.
end note

@enduml


@startuml Recommendation_Logic
title GreenChem Navigator - Recommendation Logic

skinparam shadowing false

start
:Receive current process;
:Identify current solvent;
:Identify catalyst and catalyst role;

if (Solvent known?) then (yes)
else (no)
  :Return insufficient data;
  stop
endif

if (Catalyst known?) then (yes)
else (no)
  :Return insufficient data;
  stop
endif

if (Catalyst role supported?) then (yes)
else (no)
  :Return insufficient data;
  stop
endif

:Get possible replacement solvents;

repeat
  :Check deterministic compatibility rules;
  if (Passes rules?) then (yes)
    :Run ML compatibility prediction;
    if (ML rejects candidate?) then (yes)
      :Skip candidate;
    else (no)
      :Add candidate to alternatives;
    endif
  else (no)
    :Skip candidate;
  endif
repeat while (More candidates?)

if (Alternatives found?) then (yes)
  :Rank alternatives;
  :Return recommendations with evidence;
else (no)
  :Return no compatible alternative found;
endif

stop

@enduml


@startuml PDF_Report_Flow
title GreenChem Navigator - PDF Report Export Flow

skinparam shadowing false

actor User
participant "Web Frontend" as FE
participant "FastAPI Backend" as API
participant "Recommender Engine" as Rec
participant "PDF Generator\npdf_report.py" as PDF

User -> FE : Click Export PDF
FE -> API : POST /analyze/pdf
API -> Rec : analyze(formula_text)
Rec --> API : AnalyzeResponse
API -> PDF : build_analysis_pdf(response)
PDF --> API : PDF bytes
API --> FE : application/pdf
FE -> User : Download report

note right of PDF
The report includes:
- submitted process
- detected input
- current assessment
- all alternatives
- evidence
- warnings
- AI/human validation notice
end note

@enduml
